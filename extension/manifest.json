{
  "manifest_version": 3,
  "name": "Code Review Labeler",
  "version": "0.2.1",
  "description": "Scrape annotation-platform tasks, run the /run pipeline via Claude, and fill deliverables back into the platform. Supports the 5-axis model including Addressed. Resilient Context Scope fill with multi-title fallback and diagnostic logging.",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "sidePanel"],
  "host_permissions": [
    "https://annotation-platform-henna.vercel.app/*",
    "https://annotation-hub.vercel.app/*",
    "http://localhost:5002/*"
  ],
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Code Review Labeler",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
