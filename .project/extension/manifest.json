{
  "manifest_version": 3,
  "name": "Code Review Labeler",
  "version": "0.1.0",
  "description": "Scrape annotation-platform tasks, run the /run pipeline via Claude, and fill deliverables back into the platform.",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "sidePanel"],
  "host_permissions": [
    "https://annotation-platform-henna.vercel.app/*",
    "http://localhost:5002/*"
  ],
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "action": { "default_title": "Code Review Labeler" }
}
